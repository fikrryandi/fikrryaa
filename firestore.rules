rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Portfolio segments can be read by public and written by administrative endpoints
    match /portfolio_data/{sectionId} {
      allow read, write: if true;
    }
  }
}
